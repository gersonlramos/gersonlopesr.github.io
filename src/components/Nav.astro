---
interface NavLink {
  label: string;
  href: string;
}

const homeHref = import.meta.env.BASE_URL;
const navLinks: NavLink[] = [
  { label: 'Home', href: homeHref },
  { label: 'About', href: `${homeHref}#about` },
  { label: 'Experience', href: `${homeHref}#experience` },
  { label: 'Projects', href: `${homeHref}/projects/` },
  { label: 'Contact', href: `${homeHref}#contact` },
];
const normalizedCurrentPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
---

<nav class="bg-surface border-b border-border px-4 py-6 sm:px-8">
  <div class="mx-auto flex max-w-5xl items-center justify-between">
    <a
      href={homeHref}
      class="text-[20px] font-semibold leading-tight text-foreground hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent"
    >
      Gerson Ramos
    </a>
    <ul class="flex gap-2">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={normalizedCurrentPath === link.href ? 'page' : undefined}
            class="inline-block rounded px-4 py-2 text-sm font-semibold leading-snug text-foreground hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent aria-[current=page]:text-accent aria-[current=page]:underline"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>
