---
import BaseLayout from '../layouts/BaseLayout.astro';
import { experience } from '../data/experience';

const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout>
  <section
    id="about"
    class="mx-auto flex max-w-5xl scroll-mt-24 flex-col items-center gap-4 px-4 py-12 text-center sm:py-16"
  >
    <h1 class="text-[32px] font-semibold leading-tight text-foreground">
      Gerson Lopes — Data Scientist &amp; Data Engineer
    </h1>
    <p class="max-w-2xl text-base leading-normal text-muted-foreground">
      I work as a hybrid Data Scientist and Data Engineer, building the models and the
      pipelines that carry them into production. My focus is the reasoning behind each
      decision — why a particular approach, trade-off, or architecture was chosen — and the
      measurable business impact it delivered.
    </p>
    <div class="flex flex-col items-center gap-2 sm:flex-row sm:gap-4">
      <a
        href={`${baseUrl}/resume.pdf`}
        download
        class="inline-flex items-center justify-center rounded bg-accent px-6 py-3 text-sm font-semibold leading-snug text-background hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent"
      >
        Download Resume (PDF)
      </a>
      <a
        href={`${baseUrl}/resume-pt.pdf`}
        download
        class="inline-flex items-center justify-center rounded border border-border px-6 py-3 text-sm font-semibold leading-snug text-foreground hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent"
      >
        Baixar Currículo (PT)
      </a>
    </div>
  </section>

  <section
    id="experience"
    class="mx-auto flex max-w-5xl scroll-mt-24 flex-col gap-8 px-4 py-12 sm:py-16"
  >
    <h2 class="text-center text-2xl font-semibold leading-tight text-foreground">Experience</h2>
    <ol class="flex flex-col gap-6">
      {experience.map((entry) => (
        <li class="rounded border border-border bg-surface p-6">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h3 class="text-lg font-semibold leading-snug text-foreground">
              {entry.role} · {entry.organization}
            </h3>
            <p class="font-mono text-sm text-muted-foreground">{entry.period}</p>
          </div>
          <p class="mt-2 text-base leading-normal text-muted-foreground">{entry.context}</p>
          <ul class="mt-4 flex flex-col gap-2">
            {entry.impact.map((point) => (
              <li class="flex gap-2 text-base leading-normal text-foreground">
                <span class="text-accent" aria-hidden="true">▹</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </section>

  <section
    id="contact"
    class="mx-auto flex max-w-5xl scroll-mt-24 flex-col gap-4 px-4 py-12 text-center sm:py-16"
  >
    <h2 class="text-2xl font-semibold leading-tight text-foreground">Contact</h2>
    <p class="text-base leading-normal text-muted-foreground">
      Reach out via the links in the footer below.
    </p>
  </section>
</BaseLayout>
